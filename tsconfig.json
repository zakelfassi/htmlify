{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["index.js", "src/**/*.js", "bin/**/*.js", "hooks/**/*.js", "test/**/*.js"],
  "exclude": ["node_modules", "test/fixtures"]
}
