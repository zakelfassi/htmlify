{
  "name": "@zakelfassi/htmlify",
  "version": "1.0.0",
  "private": false,
  "description": "Turn agent answers into self-contained HTML artifacts and presentation decks — operator briefs, review packets, incident timelines, decision briefs, and talks. Zero dependencies, zero build, one file.",
  "license": "Apache-2.0",
  "type": "commonjs",
  "main": "index.js",
  "bin": {
    "htmlify-answer": "bin/htmlify-answer.js"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "lint": "biome ci .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "index.js",
    "src/",
    "bin/",
    "hooks/",
    "skills/",
    ".claude-plugin/",
    "assets/",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zakelfassi/htmlify.git"
  },
  "homepage": "https://zakelfassi.github.io/htmlify/",
  "bugs": {
    "url": "https://github.com/zakelfassi/htmlify/issues"
  },
  "keywords": [
    "agentskills",
    "agent-skill",
    "deckify",
    "claude-code",
    "claude-code-plugin",
    "presentation",
    "deck",
    "oh-my-pi",
    "omp",
    "pi",
    "extension",
    "operator-brief",
    "html",
    "export",
    "gemini",
    "long-answer",
    "html-export",
    "pi-extension",
    "pi-package"
  ],
  "engines": {
    "node": ">=20"
  },
  "omp": {
    "extensions": [
      "./index.js"
    ]
  },
  "pi": {
    "extensions": [
      "./index.js"
    ]
  },
  "packageManager": "pnpm@10.34.3+sha512.f2c531b08829d7be7f03c90addc266615f9c5477463e4bf1d275cb263ce9ea57cf0d5599110d94649a9bb3fed9f0b5efcea74a7016b61532a24cb9ad87860c1d",
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^20.19.42",
    "typescript": "^6.0.3"
  }
}
