{
  "name": "@zakelfassi/htmlify",
  "version": "0.3.1",
  "private": false,
  "description": "Turn long agent answers into self-contained, browser-ready HTML artifacts for Pi, OMP, and agentskills-compatible workflows.",
  "type": "commonjs",
  "main": "index.js",
  "bin": {
    "htmlify-answer": "./bin/htmlify-answer.js"
  },
  "scripts": {
    "test": "node --test test/*.test.js"
  },
  "files": [
    "SKILL.md",
    "bin/",
    "hooks/",
    "index.js",
    "README.md",
    "assets/",
    "references/"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zakelfassi/htmlify.git"
  },
  "homepage": "https://github.com/zakelfassi/htmlify#readme",
  "bugs": {
    "url": "https://github.com/zakelfassi/htmlify/issues"
  },
  "keywords": [
    "agentskills",
    "agent-skill",
    "oh-my-pi",
    "omp",
    "pi",
    "extension",
    "operator-brief",
    "html",
    "export",
    "gemini",
    "long-answer",
    "html-export",
    "pi-extension",
    "pi-package"
  ],
  "engines": {
    "node": ">=20"
  },
  "omp": {
    "extensions": [
      "./index.js"
    ]
  },
  "pi": {
    "extensions": [
      "./index.js"
    ]
  },
  "packageManager": "pnpm@8.15.0+sha512.ea45517d5285d123eac02c3793505fa1fd6da90a2fc60d1e8d9e0c1e9292886ecfaff513f062b9d1cc8021bb8615033b1ac5bea3b2ee3fc165a6d7034bbe6b03"
}
